{
  "name": "ifasy-launcher",
  "version": "0.1.9",
  "description": "Offizieller IFASY Launcher fuer Login, Download und Updates",
  "main": "main.js",
  "author": "IFASY",
  "license": "UNLICENSED",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "release": "electron-builder --win --x64 --publish always"
  },
  "build": {
    "appId": "com.ifasy.launcher",
    "productName": "IFASY Launcher",
    "copyright": "Copyright 2026 IFASY",
    "directories": { "output": "dist" },
    "files": ["main.js", "preload.js", "renderer/**/*", "build/icon.ico"],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "build/icon.ico",
      "artifactName": "IFASY-Launcher-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "runAfterFinish": true,
      "shortcutName": "IFASY Launcher",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    },
    "publish": [{ "provider": "generic", "url": "https://ifasy.com/downloads/launcher/" }]
  },
  "devDependencies": {
    "electron": "31.7.0",
    "electron-builder": "24.13.3"
  },
  "dependencies": {
    "electron-updater": "6.3.9"
  }
}
